diff --git a/src/lib/dlt_client.c b/src/lib/dlt_client.c
index 720aa27..7013ccf 100644
--- a/src/lib/dlt_client.c
+++ b/src/lib/dlt_client.c
@@ -107,7 +107,7 @@ void dlt_client_register_message_callback(int (*registerd_callback)(DltMessage*
